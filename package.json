{
  "name": "pasadena-health-hub",
  "private": true,
  "version": "0.0.0",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev:public": "cd apps/public && bun run dev",
    "dev:portal": "cd apps/portal && bun run dev",
    "build:public": "cd apps/public && bun run build",
    "build:portal": "cd apps/portal && bun run build",
    "build": "bun run build:public && bun run build:portal",
    "type-check": "cd apps/public && bun run type-check && cd ../portal && bun run type-check",
    "seed": "bun --env-file=.env.local run scripts/seed-test-accounts.ts",
    "seed:practice-health": "bun --env-file=.env.local run scripts/seed-practice-health.ts"
  }
}

# Resend API Key (required for contact form)
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx

# Email recipients (comma-separated)
EMAIL_RECIPIENTS_CONTACT=care@hcimed.com,admin@hcimed.com
EMAIL_RECIPIENTS_APPOINTMENTS=care@hcimed.com
EMAIL_RECIPIENTS_CAREERS=admin@hcimed.com
# Optional override for the New Programs (Weight Loss + TRT) campaign landing page
# Falls back to EMAIL_RECIPIENTS_APPOINTMENTS, then care@hcimed.com.
# admin@hcimed.com is always included automatically.
EMAIL_RECIPIENTS_PROGRAMS=

# Beehiiv (newsletter subscriptions)
# Get your API key from: https://app.beehiiv.com/settings/integrations/api
# Publication ID (V2 format) is shown at: Settings → Publication ID
BEEHIIV_API_KEY=
BEEHIIV_PUBLICATION_ID=pub_xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Optional: Google Analytics tracking ID
VITE_GA_TRACKING_ID=

# Optional: Site URL (used for Open Graph meta tags)
VITE_SITE_URL=https://hcimed.com

# Supabase (required for portal/admin features)
# Get your project URL and anon key from: https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...

# Supabase Service Role Key (server-side only, for Vercel API functions)
# NEVER expose this in client-side code
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...
